# ============================================
# X96Mini Docker Compose - Environment Config
# ============================================
# Copy file ini ke .env dan isi nilai-nilainya:
#   cp .env.example .env
# ============================================

# Domain / IP Address STB
DOMAIN=192.168.1.100

# Timezone
TZ=Asia/Jakarta

# Seafile Database & Admin Password
SEAFILE_DB_PW=changeme_root
SEAFILE_ADMIN_EMAIL=admin@example.com
SEAFILE_ADMIN_PW=changeme_admin

# Akkoma Database Password
AKKOMA_DB_PW=changeme_akkoma
